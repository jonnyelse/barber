{
  "name": "barber",
  "title": "barber",
  "summary": "biallelic reconfiguration of multi-allelic strs",
  "dxapi": "1.0.0",
  "version": "0.0.1",
  "inputSpec": [
    {
      "name": "vcf_file",
      "class": "file",
      "optional": false,
      "help": ""
    },
    {
      "name": "vcf_file_index",
      "class": "file",
      "optional": false,
      "help": ""
    },
    {
      "name": "chr",
      "class": "string",
      "optional": false,
      "help": ""
    },
    {
      "name": "rename_file",
      "class": "file",
      "optional": false,
      "help": ""
    },
    {
      "name": "output_folder",
      "class": "string",
      "optional": true,
      "default": "\"\"",
      "help": ""
    },
    {
      "name": "project",
      "class": "string",
      "optional": true,
      "default": "\"\"",
      "help": ""
    }
  ],
  "outputSpec": [
    {
      "name": "split_chr",
      "class": "file",
      "patterns": [
        "*"
      ],
      "help": ""
    }
  ],
  "runSpec": {
    "execDepends": [
        {"name": "bcftools"},
        {"name": "tabix"},
        {"name": "r-base"},
        {"name": "dplyr", "package_manager": "cran"},
        {"name": "data.table", "package_manager": "cran"}
    ],
    "timeoutPolicy": {
      "*": {
        "hours": 48
      }
    },
    "interpreter": "bash",
    "release": "20.04",
    "distribution": "Ubuntu",
    "file": "src/barber.sh",
    "version": "0"
  },
  "access": {"network": ["*"],
    "project": "CONTRIBUTE"
  },
  "regionalOptions": {
    "aws:eu-west-2": {
      "systemRequirements": {
        "*": {
          "instanceType": "mem3_ssd1_v2_x4"
        }
      }
    }
  }
}